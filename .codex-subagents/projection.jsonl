aths\") or []\n   675\t    lines.append(f\"- Ignored harness-artifact paths: {_render_policy_list(ignored)}\")\n   676\t    review_requirements = task.get(\"review_requirements\") or {}\n   677\t    if task.get(\"task_kind\") == \"analysis_review\":\n   678\t        lines.append(f\"- Require evidence per recommendation: `{review_requirements.get('require_evidence_per_recommendation')}`\")\n   679\t        lines.append(f\"- Require classification: `{review_requirements.get('require_classification')}`\")\n   680\t        lines.append(f\"- Require priority: `{review_requirements.get('require_priority')}`\")\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/zsh -lc \"nl -ba anvil/harness/publication_authority.py | sed -n '1,130p'\"","aggregated_output":"     1\tfrom __future__ import annotations\n     2\t\n     3\timport copy\n     4\timport re\n     5\tfrom typing import Any\n     6\t\n     7\t_BANNED_PUBLICATION_AUTHORITY_PATTERNS = (\n     8\t    re.compile(r\"\\bFINAL[\\s_]*ANSWER\\b\", re.IGNORECASE),\n     9\t    re.compile(r\"\\bfinal artifact\\b\", re.IGNORECASE),\n    10\t    re.compile(r\"\\bpublication[- ]ready\\b\", re.IGNORECASE),\n    11\t    re.compile(r\"\\bready to publish\\b\", re.IGNORECASE),\n    12\t)\n    13\t\n    14\t_SUMMARY_REPLACEMENTS = {\n    15\t    \"deliverable_summary\": (\n    16\t        \"Runner note: model-authored summary withheld because publication eligibility is \"\n    17\t        \"runner-owned.\"\n    18\t    ),\n    19\t    \"recommendation_review\": (\n    20\t        \"Runner note: review summary withheld because publication eligibility is runner-owned.\"\n    21\t    ),\n    22\t    \"draft_summary\": (\n    23\t        \"Runner note: draft summary withheld because publication eligibility is runner-owned.\"\n    24\t    ),\n    25\t}\n    26\t\n    27\t\n    28\tdef contains_publication_authority_claim(text: Any) -> bool:\n    29\t    value = str(text or \"\").strip()\n    30\t    if not value:\n    31\t        return False\n    32\t    return any(pattern.search(value) for pattern in _BANNED_PUBLICATION_AUTHORITY_PATTERNS)\n    33\t\n    34\t\n    35\tdef sanitize_summary_text(text: Any, *, surface: str) -> str:\n    36\t    value = str(text or \"\").strip()\n    37\t    if not value:\n    38\t        return \"\"\n    39\t    if not contains_publication_authority_claim(value):\n    40\t        return value\n    41\t    try:\n    42\t        return _SUMMARY_REPLACEMENTS[surface]\n    43\t    except KeyError as exc:\n    44\t        raise ValueError(f\"Unsupported publication-authority summary surface: {surface!r}\") from exc\n    45\t\n    46\t\n    47\tdef partial_acceptance_summary_suffix(\n    48\t    included_recommendation_indices: list[int],\n    49\t    excluded_recommendation_indices: list[int],\n    50\t) -> str:\n    51\t    return (\n    52\t        f\"Partial acceptance: recommendations {', '.join(str(i) for i in included_recommendation_indices)} \"\n    53\t        f\"are included; recommendations \"\n    54\t        f\"{', '.join(str(i) for i in excluded_recommendation_indices) or 'none'} were excluded.\"\n    55\t    )\n    56\t\n    57\t\n    58\tdef sanitize_recommendation_reviews(\n    59\t    recommendation_reviews: Any,\n    60\t) -> list[dict[str, Any]] | Any:\n    61\t    if not isinstance(recommendation_reviews, list):\n    62\t        return recommendation_reviews\n    63\t    sanitized_reviews: list[dict[str, Any]] = []\n    64\t    for item in recommendation_reviews:\n    65\t        if not isinstance(item, dict):\n    66\t            sanitized_reviews.append(item)\n    67\t            continue\n    68\t        sanitized_item = copy.deepcopy(item)\n    69\t        sanitized_item[\"summary\"] = sanitize_summary_text(\n    70\t            sanitized_item.get(\"summary\"),\n    71\t            surface=\"recommendation_review\",\n    72\t        )\n    73\t        sanitized_reviews.append(sanitized_item)\n    74\t    return sanitized_reviews\n    75\t\n    76\t\n    77\tdef sanitize_artifact_payload(\n    78\t    payload: dict[str, Any],\n    79\t    *,\n    80\t    artifact_kind: str,\n    81\t) -> dict[str, Any]:\n    82\t    sanitized = copy.deepcopy(payload)\n    83\t    summary_text = str(sanitized.get(\"summary\") or \"\").strip()\n    84\t    if artifact_kind == \"partial_answer\":\n    85\t        included_indices = _normalized_recommendation_indices(\n    86\t            sanitized.get(\"included_recommendation_indices\")\n    87\t        )\n    88\t        excluded_indices = _normalized_recommendation_indices(\n    89\t            sanitized.get(\"excluded_recommendation_indices\")\n    90\t        )\n    91\t        suffix = partial_acceptance_summary_suffix(included_indices, excluded_indices)\n    92\t        if summary_text.endswith(suffix):\n    93\t            model_summary = summary_text[: -len(suffix)].rstrip()\n    94\t            sanitized_model_summary = sanitize_summary_text(\n    95\t                model_summary,\n    96\t                surface=\"deliverable_summary\",\n    97\t            )\n    98\t            parts = [part for part in (sanitized_model_summary, suffix) if part]\n    99\t            sanitized[\"summary\"] = \"\\n\\n\".join(parts).strip()\n   100\t        else:\n   101\t            sanitized[\"summary\"] = sanitize_summary_text(\n   102\t                summary_text,\n   103\t                surface=\"deliverable_summary\",\n   104\t            )\n   105\t    else:\n   106\t        sanitized[\"summary\"] = sanitize_summary_text(\n   107\t            summary_text,\n   108\t            surface=\"deliverable_summary\",\n   109\t        )\n   110\t    sanitized[\"recommendation_reviews\"] = sanitize_recommendation_reviews(\n   111\t        sanitized.get(\"recommendation_reviews\")\n   112\t    )\n   113\t    return sanitized\n   114\t\n   115\t\n   116\tdef _normalized_recommendation_indices(raw_items: Any) -> list[int]:\n   117\t    indices: list[int] = []\n   118\t    for item in raw_items or []:\n   119\t        try:\n   120\t            indices.append(int(item))\n   121\t        except (TypeError, ValueError):\n   122\t            continue\n   123\t    return sorted(set(indices))\n","exit_code":0,"status":"completed"}}
