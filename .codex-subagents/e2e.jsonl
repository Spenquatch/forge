    ),\n    98\t        \"excluded_recommendation_indices\": _normalized_recommendation_indices(\n    99\t            raw_admissibility.get(\"excluded_recommendation_indices\")\n   100\t        ),\n   101\t        \"reasons_by_recommendation_index\": reasons_by_index,\n   102\t    }\n   103\t    if not any(\n   104\t        (\n   105\t            normalized[\"final_answer_recommendation_indices\"],\n   106\t            normalized[\"partial_only_recommendation_indices\"],\n   107\t            normalized[\"excluded_recommendation_indices\"],\n   108\t            normalized[\"reasons_by_recommendation_index\"],\n   109\t        )\n   110\t    ):\n   111\t        return {}\n   112\t    return normalized\n   113\t\n   114\t\n   115\tdef _recommendation_withholding_entries(\n   116\t    recommendation_admissibility: dict[str, Any],\n   117\t) -> list[dict[str, Any]]:\n   118\t    reasons_by_index = (\n   119\t        recommendation_admissibility.get(\"reasons_by_recommendation_index\") or {}\n   120\t    )\n   121\t    withheld_indices = sorted(\n   122\t        set(\n   123\t            recommendation_admissibility.get(\"partial_only_recommendation_indices\") or []\n   124\t        ).union(recommendation_admissibility.get(\"excluded_recommendation_indices\") or [])\n   125\t    )\n   126\t    entries: list[dict[str, Any]] = []\n   127\t    for recommendation_index in withheld_indices:\n   128\t        reasons = [\n   129\t            str(reason).strip()\n   130\t            for reason in (reasons_by_index.get(str(recommendation_index)) or [])\n   131\t            if str(reason).strip() in _CANONICAL_ADMISSIBILITY_REASONS\n   132\t        ]\n   133\t        if not reasons:\n   134\t            continue\n   135\t        entries.append(\n   136\t            {\n   137\t                \"recommendation_index\": recommendation_index,\n   138\t                \"reasons\": reasons,\n   139\t            }\n   140\t        )\n   141\t    return entries\n   142\t\n   143\t\n   144\tdef _partial_acceptance_min_accepted_recommendations(summary: dict[str, Any]) -> int:\n   145\t    contract = summary.get(\"analysis_review_contract\") or {}\n   146\t    partial_acceptance = contract.get(\"partial_acceptance\") or {}\n   147\t    raw_minimum = partial_acceptance.get(\"min_accepted_recommendations\")\n   148\t    if raw_minimum is None:\n   149\t        raw_minimum = ((summary.get(\"task\") or {}).get(\"review_requirements\") or {}).get(\n   150\t            \"min_recommendations\"\n   151\t        )\n   152\t    try:\n   153\t        return max(1, int(raw_minimum))\n   154\t    except (TypeError, ValueError):\n   155\t        return 1\n   156\t\n   157\t\n   158\tdef _partial_candidate_recommendation_indices(summary: dict[str, Any]) -> list[int]:\n   159\t    admissibility = _recommendation_admissibility(summary)\n   160\t    if admissibility:\n   161\t        return sorted(\n   162\t            set(admissibility[\"final_answer_recommendation_indices\"]).union(\n   163\t                admissibility[\"partial_only_recommendation_indices\"]\n   164\t            )\n   165\t        )\n   166\t    return _accepted_recommendation_indices(summary)\n   167\t\n   168\t\n   169\tdef _recommendation_exclusion_reasons_by_index(\n   170\t    summary: dict[str, Any],\n   171\t    *,\n   172\t    source_recommendation_indices: list[int],\n   173\t    included_recommendation_indices: list[int],\n   174\t) -> dict[str, list[str]]:\n   175\t    included_index_set = set(included_recommendation_indices)\n   176\t    admissibility = _recommendation_admissibility(summary)\n   177\t    if admissibility:\n   178\t        reasons_by_index = admissibility.get(\"reasons_by_recommendation_index\") or {}\n   179\t        return {\n   180\t            str(index): list(reasons_by_index.get(str(index)) or [])\n   181\t            for index in source_recommendation_indices\n   182\t            if index not in included_index_set and list(reasons_by_index.get(str(index)) or [])\n   183\t        }\n   184\t\n   185\t    candidate_indices = set(_partial_candidate_recommendation_indices(summary))\n   186\t    topic_eligibility = partial_accept_topic_eligibility(\n   187\t        _topic_ledger(summary),\n   188\t        accepted_recommendation_indices=sorted(candidate_indices),\n   189\t    )\n   190\t    topic_blocked_indices = set(topic_eligibility[\"blocked_recommendation_indices\"])\n   191\t    reasons_by_index: dict[str, list[str]] = {}\n   192\t    for index in source_recommendation_indices:\n   193\t        if index in included_index_set:\n   194\t            continue\n   195\t        if index in topic_blocked_indices:\n   196\t            reasons_by_index[str(index)] = [\"topic_blocked\"]\n   197\t        elif index not in candidate_indices:\n   198\t            reasons_by_index[str(index)] = [\"not_accepted\"]\n   199\t    return reasons_by_index\n   200\t\n   201\t\n   202\tdef _final_answer_admissible(summary: dict[str, Any], payload: dict[str, Any]) -> bool:\n   203\t    admissibility = _recommendation_admissibility(summary)\n   204\t    if not admissibility:\n   205\t        return True\n   206\t\n   207\t    recommendations = payload.get(\"recommendations\")\n   208\t    recommendation_count = len(recommendations) if isinstance(recommendations, list) else 0\n   209\t    source_indices = _recommendation_source_indices(payload, recommendation_count)\n   210\t    return (\n   211\t        source_indices == admissibility[\"final_answer_recommendation_indices\"]\n   212\t        and not admissibility[\"partial_only_recommendation_indices\"]\n   213\t        and not admissibility[\"excluded_recommendation_indices\"]\n   214\t    )\n   215\t\n   216\t\n   217\tdef _partial_answer_eligibility(summary: dict[str, Any]) -> tuple[bool, list[int]]:\n   218\t    candidate_indices = _partial_candidate_recommendation_indices(summary)\n   219\t    if not candidate_indices:\n   220\t        return (False, [])\n   221\t\n   222\t    analysis_status = _analysis_review_status(summary)\n   223\t    provenance = analysis_status.get(\"provenance\") or {}\n   224\t    review_mode = str(analysis_status.get(\"mode\") or \"\").strip().lower()\n   225\t    provenance_policy = str(provenance.get(\"policy_mode\") or \"\").strip().lower()\n   226\t    provenance_status = str(provenance.get(\"status\") or \"\").strip().lower()\n   227\t    if review_mode == \"trust\" and provenance_policy == \"payload_hash_and_refs\":\n   228\t        if provenance_status != \"bound\":\n   229\t            return (False, [])\n   230\t\n   231\t    topic_eligibility = partial_accept_topic_eligibility(\n   232\t        _topic_ledger(summary),\n   233\t        accepted_recommendation_indices=candidate_indices,\n   234\t    )\n   235\t    if topic_eligibility[\"global_blocking_topic_ids\"]:\n   236\t        return (False, [])\n   237\t\n   238\t    eligible_indices = list(topic_eligibility[\"eligible_recommendation_indices\"])\n   239\t    if len(eligible_indices) < _partial_acceptance_min_accepted_recommendations(summary):\n   240\t        return (False, [])\n","exit_code":0,"status":"completed"}}
