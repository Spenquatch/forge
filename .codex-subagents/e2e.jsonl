     \"uncovered_global_topic_ids\": list(\n  2341\t                    provenance.get(\"uncovered_global_topic_ids\") or []\n  2342\t                ),\n  2343\t                \"closure_proof_by_id\": dict(provenance.get(\"closure_proof_by_id\") or {}),\n  2344\t            }\n  2345\t            records.append(record)\n  2346\t        return records\n  2347\t\n  2348\t    def _final_payload_provenance_status(self) -> str:\n  2349\t        records = self._final_payload_provenance_records()\n  2350\t        if not records:\n  2351\t            return \"missing\"\n  2352\t        statuses = {str(item.get(\"status\") or \"missing\") for item in records}\n  2353\t        if \"insufficient\" in statuses:\n  2354\t            return \"insufficient\"\n  2355\t        if statuses == {\"bound\"}:\n  2356\t            return \"bound\"\n  2357\t        if \"bound\" in statuses:\n  2358\t            return \"partial\"\n  2359\t        if \"not_required\" in statuses and statuses <= {\"not_required\", \"missing\"}:\n  2360\t            return \"not_required\"\n  2361\t        return \"missing\"\n  2362\t\n  2363\t    def _build_analysis_review_status(\n  2364\t        self,\n  2365\t        *,\n  2366\t        final_analysis_payload: dict[str, Any],\n  2367\t        final_review_payload: dict[str, Any],\n  2368\t        content_verdict: str,\n  2369\t    ) -> dict[str, Any]:\n  2370\t        contract = self._analysis_contract()\n  2371\t        semantic_warning_records = self._final_semantic_warning_records()\n  2372\t        provenance_records = self._final_payload_provenance_records()\n  2373\t        accepted_caveat_indices = self._accepted_caveat_recommendation_indices(final_review_payload)\n  2374\t        inferred_indices = self._accepted_inferred_recommendation_indices(\n  2375\t            final_analysis_payload,\n  2376\t            final_review_payload,\n  2377\t        )\n  2378\t        downgrade_causes = self._analysis_warning_causes(\n  2379\t            final_review_payload,\n  2380\t            final_analysis_payload=final_analysis_payload,\n  2381\t        )\n  2382\t        provenance_status = self._final_payload_provenance_status()\n  2383\t        open_topic_ids = topic_ids_for_status_name(self.topic_ledger, status_name=\"open\")\n  2384\t        carried_forward_topic_ids = topic_ids_for_status_name(\n  2385\t            self.topic_ledger,\n  2386\t            status_name=\"carried_forward\",\n  2387\t        )\n  2388\t        waived_topic_ids = topic_ids_for_status_name(self.topic_ledger, status_name=\"waived\")\n  2389\t        resolved_topic_ids = topic_ids_for_status_name(self.topic_ledger, status_name=\"resolved\")\n  2390\t        disagreed_topic_ids = topic_ids_for_status_name(self.topic_ledger, status_name=\"disagreed\")\n  2391\t        review_provenance = next(\n  2392\t            (item for item in provenance_records if str(item.get(\"surface\") or \"\") == \"review\"),\n  2393\t            {},\n  2394\t        )\n  2395\t        if contract.trust_review.payload_provenance_mode == \"none\" and provenance_status == \"missing\":\n  2396\t            provenance_status = \"not_required\"\n  2397\t        publishability = self._analysis_publishability(content_verdict=content_verdict)\n  2398\t        recommendation_admissibility = self._build_recommendation_admissibility(\n  2399\t            final_analysis_payload=final_analysis_payload,\n  2400\t            final_review_payload=final_review_payload,\n  2401\t        )\n  2402\t        return {\n  2403\t            \"mode\": contract.mode,\n  2404\t            \"content_verdict\": content_verdict,\n  2405\t            \"semantic_warning_count\": len(semantic_warning_records),\n  2406\t            \"semantic_warnings\": semantic_warning_records,\n  2407\t            \"provenance\": {\n  2408\t                \"status\": provenance_status,\n  2409\t                \"policy_mode\": contract.trust_review.payload_provenance_mode,\n  2410\t                \"required\": contract.trust_review.payload_provenance_mode == \"payload_hash_and_refs\",\n  2411\t                \"issue_closure_review_ref_count\": review_provenance.get(\n  2412\t                    \"issue_closure_review_ref_count\",\n  2413\t                    0,\n  2414\t                ),\n  2415\t                \"topic_closure_review_ref_count\": review_provenance.get(\n  2416\t                    \"topic_closure_review_ref_count\",\n  2417\t                    0,\n  2418\t                ),\n  2419\t                \"closure_complete_issue_ids\": list(\n  2420\t                    review_provenance.get(\"closure_complete_issue_ids\") or []\n  2421\t                ),\n  2422\t                \"closure_complete_topic_ids\": list(\n  2423\t                    review_provenance.get(\"closure_complete_topic_ids\") or []\n  2424\t                ),\n  2425\t                \"uncovered_recommendation_indices\": list(\n  2426\t                    review_provenance.get(\"uncovered_recommendation_indices\") or []\n  2427\t                ),\n  2428\t                \"uncovered_global_issue_ids\": list(\n  2429\t                    review_provenance.get(\"uncovered_global_issue_ids\") or []\n  2430\t                ),\n  2431\t                \"uncovered_global_topic_ids\": list(\n  2432\t                    review_provenance.get(\"uncovered_global_topic_ids\") or []\n  2433\t                ),\n  2434\t                \"closure_proof_by_id\": dict(review_provenance.get(\"closure_proof_by_id\") or {}),\n  2435\t                \"stages\": provenance_records,\n  2436\t            },\n  2437\t            \"accepted_recommendations_with_caveats\": accepted_caveat_indices,\n  2438\t            \"accepted_recommendations_with_inferred_grounding\": inferred_indices,\n  2439\t            \"open_topic_ids\": open_topic_ids,\n  2440\t            \"carried_forward_topic_ids\": carried_forward_topic_ids,\n  2441\t            \"waived_topic_ids\": waived_topic_ids,\n  2442\t            \"resolved_topic_ids\": resolved_topic_ids,\n  2443\t            \"disagreed_topic_ids\": disagreed_topic_ids,\n  2444\t            \"topic_ledger_count\": len(self.topic_ledger),\n  2445\t            \"downgrade_causes\": downgrade_causes,\n  2446\t            \"recommendation_admissibility\": recommendation_admissibility,\n  2447\t            \"publishability\": publishability,\n  2448\t        }\n  2449\t\n  2450\t    def _blocking_issues(self, review_payload: dict[str, Any]) -> list[dict[str, Any]]:\n  2451\t        blocking: list[dict[str, Any]] = []\n  2452\t        for issue in review_payload.get(\"issues\", []) or []:\n  2453\t            if not isinstance(issue, dict):\n  2454\t                continue\n  2455\t            severity = str(issue.get(\"severity\") or \"\").strip().lower()\n  2456\t            blocking_class = str(issue.get(\"blocking_class\") or \"presentation\").strip().lower()\n  2457\t            if severity in {\"medium\", \"high\", \"critical\"} and blocking_class in {\n  2458\t                \"correctness\",\n  2459\t                \"actionability\",\n  2460\t                \"completeness\",\n  2461\t            }:\n  2462\t                blocking.append(issue)\n  2463\t        return blocking\n  2464\t\n  2465\t    def _score_threshold_failures(self, review_payload: dict[str, Any]) -> list[str]:\n","exit_code":0,"status":"completed"}}
